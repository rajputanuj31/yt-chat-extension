{
  "manifest_version": 3,
  "name": "YouTube Video Chat",
  "version": "0.1.0",
  "description": "Chat with YouTube videos using AI. Ask questions about the video content.",
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "192": "icon192.png",
    "512": "icon512.png"
  },
  "action": {
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png"
    }
  },
  "permissions": ["storage"],
  "host_permissions": [
    "http://127.0.0.1:8000/*",
    "http://localhost/*",
    "http://127.0.0.1/*",
    "https://*/*"
  ],
  "options_ui": {
    "page": "options.html"
  },
  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/watch*"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ]
}
