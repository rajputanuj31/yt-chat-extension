# Backend config (optional). OpenAI API key is sent by the extension per request.
# HOST=0.0.0.0
# PORT=8000

# CORS: comma-separated list of allowed origins (e.g. your extension or frontend).
# Leave unset or use "*" to allow all. For production, set e.g.:
# CORS_ORIGINS=https://yourdomain.com,chrome-extension://YOUR_EXTENSION_ID
# CORS_ORIGINS=*
